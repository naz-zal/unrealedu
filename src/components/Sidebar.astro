---
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import Search from 'virtual:starlight/components/Search';
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import SidebarSublist from '@astrojs/starlight/components/SidebarSublist.astro';

const { sidebar } = Astro.locals.starlightRoute;
const base = import.meta.env.BASE_URL;
const categories = [
  { key: 'uefn', label: 'UEFN', href: `${base}uefn/introduction/` },
];
const selectedCategory = categories.find((category) => Astro.url.pathname.includes(`/${category.key}/`)) ?? categories[0];
---

<script is:inline>
  (() => {
    try {
      const isCollapsed = localStorage.getItem('docs-sidebar-collapsed') === 'true';
      document.documentElement.dataset.sidebarCollapsed = String(isCollapsed);
    } catch {
      document.documentElement.dataset.sidebarCollapsed = 'false';
    }
  })();
</script>

<div class="docs-sidebar-top">
  <div class="docs-sidebar-brand-row">
    <a class="docs-sidebar-brand" href={base} translate="no" aria-label="Epic Games Education home">
      <span class="docs-sidebar-mark" aria-hidden="true"></span>
      <span>Epic Games Education</span>
    </a>
    <button class="docs-sidebar-collapse" type="button" data-sidebar-toggle aria-label="Hide sidebar" title="Hide sidebar" aria-expanded="true">
      <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="5" y="4" width="14" height="16" rx="2"></rect>
        <path d="M11 4v16"></path>
      </svg>
    </button>
  </div>
  <div class="docs-sidebar-search">
    <Search />
  </div>
  <div class="docs-category-picker" data-category-picker>
    <button class="docs-category-trigger" type="button" data-category-trigger aria-haspopup="menu" aria-expanded="false">
      <span class="docs-category-icon" aria-hidden="true"></span>
      <span>{selectedCategory.label}</span>
      <svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m6 9 6 6 6-6"></path>
      </svg>
    </button>
    <div class="docs-category-menu" data-category-menu role="menu" hidden>
      {categories.map((category) => (
        <a href={category.href} role="menuitem" aria-current={category.key === selectedCategory.key ? 'true' : undefined} data-category={category.key}>
          {category.label}
        </a>
      ))}
    </div>
  </div>
</div>

<div class="docs-sidebar-nav">
  <SidebarPersister>
    <SidebarSublist sublist={sidebar} />
  </SidebarPersister>
</div>

<div class="md:sl-hidden">
  <MobileMenuFooter />
</div>

<script>
  const root = document.documentElement;
  const setCollapsed = (collapsed: boolean) => {
    root.dataset.sidebarCollapsed = String(collapsed);
    for (const button of document.querySelectorAll<HTMLButtonElement>('[data-sidebar-toggle]')) {
      button.setAttribute('aria-expanded', String(!collapsed));
      button.setAttribute('aria-label', collapsed ? 'Show sidebar' : 'Hide sidebar');
      button.title = collapsed ? 'Show sidebar' : 'Hide sidebar';
    }
    try {
      localStorage.setItem('docs-sidebar-collapsed', String(collapsed));
    } catch {}
  };

  setCollapsed(root.dataset.sidebarCollapsed === 'true');

  for (const button of document.querySelectorAll<HTMLButtonElement>('[data-sidebar-toggle]')) {
    button.addEventListener('click', () => setCollapsed(root.dataset.sidebarCollapsed !== 'true'));
  }

  for (const button of document.querySelectorAll<HTMLButtonElement>('[data-sidebar-restore]')) {
    button.addEventListener('click', () => setCollapsed(false));
  }

  for (const picker of document.querySelectorAll<HTMLElement>('[data-category-picker]')) {
    const trigger = picker.querySelector<HTMLButtonElement>('[data-category-trigger]');
    const menu = picker.querySelector<HTMLElement>('[data-category-menu]');
    if (!trigger || !menu) continue;

    const closeMenu = () => {
      menu.hidden = true;
      trigger.setAttribute('aria-expanded', 'false');
    };

    trigger.addEventListener('click', (event) => {
      event.stopPropagation();
      const nextOpen = menu.hidden;
      menu.hidden = !nextOpen;
      trigger.setAttribute('aria-expanded', String(nextOpen));
    });

    document.addEventListener('click', (event) => {
      if (!picker.contains(event.target as Node)) closeMenu();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMenu();
    });
  }
</script>