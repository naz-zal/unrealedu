---
const restoreLabel = 'Show sidebar';
---

<div class="docs-mobile-header" translate="no">Epic Games Education</div>
<button class="docs-sidebar-restore" type="button" data-sidebar-restore aria-label={restoreLabel} title={restoreLabel}>
  <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <rect x="5" y="4" width="14" height="16" rx="2"></rect>
    <path d="M11 4v16"></path>
  </svg>
</button>